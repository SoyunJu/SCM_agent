# Google API
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service_account.json
SPREADSHEET_ID=
DOCS_FOLDER_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000

# HuggingFace
HF_MODEL_NAME=snunlp/KR-FinBert-SC

# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_SIGNING_SECRET=

# MariaDB
DB_HOST=db
DB_PORT=3306
DB_NAME=scm_agent
DB_USER=scm_user
DB_PASSWORD=
DB_ROOT_PASSWORD=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Scheduler (보고서 생성)
SCHEDULE_HOUR=0
SCHEDULE_MINUTE=0
TIMEZONE=Asia/Seoul

# Crawler 컨테이너 스케줄 (기본: 매일 23:00)
CRAWLER_SCHEDULE_HOUR=23
CRAWLER_SCHEDULE_MINUTE=0

# App
APP_ENV=development
LOG_LEVEL=INFO

# 엑셀 데이터 경로
EXCEL_PATH=./sample_data.xlsx