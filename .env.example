# ────────────────────────────────────────────────────────
# SCM Agent — 환경변수 설정 예시
# 복사 후 .env로 저장하고 값을 채워주세요
# cp .env.example .env
# ────────────────────────────────────────────────────────

# Google API
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service_account.json
SPREADSHEET_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000

# HuggingFace
HF_MODEL_NAME=snunlp/KR-FinBert-SC

# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_SIGNING_SECRET=

# MariaDB
# 로컬 직접 실행 시: DB_HOST=localhost, DB_PORT=3307
# Docker 실행 시:   DB_HOST=db,        DB_PORT=3306
DB_HOST=db
DB_PORT=3306
DB_NAME=scm_db
DB_USER=
DB_PASSWORD=
DB_ROOT_PASSWORD=

# JWT
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Scheduler
SCHEDULE_HOUR=0
SCHEDULE_MINUTE=0
TIMEZONE=Asia/Seoul

# Email (SMTP)
# Gmail 사용 시 SMTP_PASSWORD는 앱 비밀번호 사용 (계정 비밀번호 X)
# Google 계정 → 보안 → 앱 비밀번호에서 생성
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=SCM Agent
ALERT_EMAIL_TO=
SMTP_TLS=true

# App
APP_ENV=development
LOG_LEVEL=INFO

# Celery / RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//